#!/bin/bash

# ============================================================
#  lk-vpn - Route x-ui Xray traffic through LK exit node
#  GitHub: https://github.com/YOUR_USERNAME/lk-vpn
# ============================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

XRAY_CONFIG_PATH="/usr/local/x-ui/bin/config.json"
BACKUP_PATH="/usr/local/x-ui/bin/config.json.bak"
XRAY_BIN="/usr/local/x-ui/bin/xray-linux-amd64"

LK_OUTBOUND='{
  "tag": "lk-out",
  "protocol": "vless",
  "settings": {
    "vnext": [{
      "address": "panel.trackydev.site",
      "port": 443,
      "users": [{
        "id": "9268fe8c-fe3f-44fe-8984-c7d0060465a1",
        "encryption": "none",
        "flow": ""
      }]
    }]
  },
  "streamSettings": {
    "network": "ws",
    "security": "tls",
    "tlsSettings": {
      "serverName": "t.me",
      "allowInsecure": true,
      "fingerprint": "chrome",
      "alpn": ["h2", "http/1.1"]
    },
    "wsSettings": {
      "path": "/",
      "headers": {
        "Host": "panel.trackydev.site"
      }
    }
  }
}'

ROUTING_RULE='{
  "type": "field",
  "outboundTag": "lk-out",
  "network": "tcp,udp"
}'

check_deps() {
    for dep in python3 curl; do
        if ! command -v $dep &>/dev/null; then
            echo -e "${RED}[!] Missing dependency: $dep${NC}"
            exit 1
        fi
    done
}

check_xui() {
    if [ ! -f "$XRAY_CONFIG_PATH" ]; then
        echo -e "${RED}[!] x-ui config not found at $XRAY_CONFIG_PATH${NC}"
        echo -e "${YELLOW}[?] Make sure x-ui is installed.${NC}"
        exit 1
    fi
}

backup_config() {
    cp "$XRAY_CONFIG_PATH" "$BACKUP_PATH"
    echo -e "${CYAN}[*] Backup saved: $BACKUP_PATH${NC}"
}

restore_config() {
    if [ -f "$BACKUP_PATH" ]; then
        cp "$BACKUP_PATH" "$XRAY_CONFIG_PATH"
        echo -e "${GREEN}[+] Config restored from backup.${NC}"
        restart_xui
    else
        echo -e "${RED}[!] No backup found.${NC}"
    fi
}

apply_config() {
    echo -e "${CYAN}[*] Applying LK exit node to Xray config...${NC}"

    python3 - <<PYEOF
import json, sys

config_path = "$XRAY_CONFIG_PATH"
lk_outbound = $LK_OUTBOUND
routing_rule = $ROUTING_RULE

with open(config_path, 'r') as f:
    config = json.load(f)

# Remove any existing lk-out outbound
config['outbounds'] = [o for o in config.get('outbounds', []) if o.get('tag') != 'lk-out']

# Add lk-out as first outbound
config['outbounds'].insert(0, lk_outbound)

# Set up routing
if 'routing' not in config:
    config['routing'] = {'rules': []}
if 'rules' not in config['routing']:
    config['routing']['rules'] = []

# Remove existing catch-all lk-out rule if any
config['routing']['rules'] = [r for r in config['routing']['rules'] if r.get('outboundTag') != 'lk-out']

# Add catch-all rule to route all traffic through lk-out
config['routing']['rules'].append(routing_rule)

with open(config_path, 'w') as f:
    json.dump(config, f, indent=2)

print("Config patched successfully.")
PYEOF

    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[+] LK exit node applied.${NC}"
    else
        echo -e "${RED}[!] Failed to patch config. Restoring backup...${NC}"
        restore_config
        exit 1
    fi
}

restart_xui() {
    echo -e "${CYAN}[*] Restarting x-ui...${NC}"
    systemctl restart x-ui 2>/dev/null || x-ui restart 2>/dev/null
    sleep 2
    if systemctl is-active --quiet x-ui; then
        echo -e "${GREEN}[+] x-ui restarted successfully.${NC}"
    else
        echo -e "${RED}[!] x-ui restart failed. Check: systemctl status x-ui${NC}"
    fi
}

check_ip() {
    echo -e "${CYAN}[*] Checking current exit IP...${NC}"
    IP=$(curl -s --max-time 10 https://api.ipify.org 2>/dev/null)
    if [ -n "$IP" ]; then
        INFO=$(curl -s --max-time 10 "https://ipapi.co/${IP}/json/" 2>/dev/null)
        COUNTRY=$(echo $INFO | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('country_name','Unknown'))" 2>/dev/null)
        CITY=$(echo $INFO | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('city','Unknown'))" 2>/dev/null)
        ISP=$(echo $INFO | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('org','Unknown'))" 2>/dev/null)
        echo -e "${GREEN}[+] Exit IP : $IP${NC}"
        echo -e "${GREEN}[+] Country : $COUNTRY${NC}"
        echo -e "${GREEN}[+] City    : $CITY${NC}"
        echo -e "${GREEN}[+] ISP     : $ISP${NC}"
    else
        echo -e "${RED}[!] Could not fetch IP.${NC}"
    fi
}

show_menu() {
    echo ""
    echo -e "${CYAN}╔══════════════════════════════╗${NC}"
    echo -e "${CYAN}║        lk-vpn Manager        ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════╝${NC}"
    echo -e " ${GREEN}1.${NC} Apply LK exit node"
    echo -e " ${GREEN}2.${NC} Remove LK exit node (restore)"
    echo -e " ${GREEN}3.${NC} Check current exit IP"
    echo -e " ${GREEN}4.${NC} Restart x-ui"
    echo -e " ${GREEN}0.${NC} Exit"
    echo ""
    read -p " Select option: " choice

    case $choice in
        1)
            check_xui
            backup_config
            apply_config
            restart_xui
            sleep 3
            check_ip
            ;;
        2)
            restore_config
            ;;
        3)
            check_ip
            ;;
        4)
            restart_xui
            ;;
        0)
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid option.${NC}"
            show_menu
            ;;
    esac
}

# ---- Main ----
check_deps
show_menu
